# BOT_TOKEN: The token you received from BotFather in Telegram.
BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# DATABASE CONFIGURATION
# Set these according to your MySQL server configuration
DB_HOST="localhost"
DB_USER="root"
DB_PASS="password"
DB_NAME="telegram_bot"

# ADMIN_IDS: Comma separated Telegram IDs
ADMIN_IDS="123456789,987654321"

# SMM NUSANTARA API CONFIGURATION
SMM_API_URL="https://api.smm.net/v2"
SMM_API_KEY="YOUR_SMM_API_KEY"
MARKUP_PERCENT=20

# PAYMENT GATEWAY (TRIPAY)
TRIPAY_API_KEY="YOUR_TRIPAY_API_KEY"
TRIPAY_PRIVATE_KEY="YOUR_TRIPAY_PRIVATE_KEY"
TRIPAY_MERCHANT_CODE="YOUR_TRIPAY_MERCHANT_CODE"
TRIPAY_IS_PRODUCTION=false

# PORT: For the express healthcheck HTTP Server (default 3000)
PORT=3000

# DATABASE URL FOR PRISMA
DATABASE_URL="mysql://root:password@localhost:3306/telegram_bot"

# JWT SECRET FOR ADMIN DASHBOARD
JWT_SECRET="changethissecret123"
