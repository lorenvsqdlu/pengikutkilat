generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id          Int       @id @default(autoincrement())
  telegram_id BigInt    @unique
  username    String?   @db.VarChar(255)
  fullname    String?   @db.VarChar(255)
  balance     Decimal   @default(0) @db.Decimal(15, 2)
  is_banned   Boolean   @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  orders      orders[]
  deposits    deposits[]
  refunds     refunds[]
}

model orders {
  id           Int       @id @default(autoincrement())
  user_id      BigInt
  service_id   String    @db.VarChar(50)
  api_order_id String?   @db.VarChar(50)
  target       String    @db.VarChar(255)
  quantity     Int
  price        Decimal   @db.Decimal(15, 2)
  profit       Decimal?  @default(0) @db.Decimal(15, 2)
  status       String?   @default("Pending") @db.VarChar(50)
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  users        users     @relation(fields: [user_id], references: [telegram_id], onDelete: NoAction, onUpdate: NoAction)
  refunds      refunds[]
}

model deposits {
  id             Int       @id @default(autoincrement())
  user_id        BigInt
  reference_id   String    @unique @db.VarChar(100)
  amount         Decimal   @db.Decimal(15, 2)
  fee            Decimal?  @default(0) @db.Decimal(15, 2)
  status         String?   @default("Pending") @db.VarChar(50)
  payment_method String?   @db.VarChar(50)
  pay_url        String?   @db.Text
  proof_image    String?   @db.Text
  admin_id       BigInt?
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  paid_at        DateTime? @db.Timestamp(0)
  approved_at    DateTime? @db.Timestamp(0)
  users          users     @relation(fields: [user_id], references: [telegram_id], onDelete: NoAction, onUpdate: NoAction)
}

model qris_accounts {
  id         Int       @id @default(autoincrement())
  qris_name  String    @db.VarChar(100)
  qris_image String    @db.Text
  is_active  Boolean   @default(true)
  created_at DateTime? @default(now()) @db.Timestamp(0)
}

model banks {
  id             Int       @id @default(autoincrement())
  bank_name      String    @db.VarChar(100)
  account_number String    @db.VarChar(100)
  account_name   String    @db.VarChar(100)
  is_active      Boolean   @default(true)
  created_at     DateTime? @default(now()) @db.Timestamp(0)
}

model refunds {
  id         Int       @id @default(autoincrement())
  order_id   Int
  user_id    BigInt
  amount     Decimal   @db.Decimal(15, 2)
  reason     String    @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  orders     orders    @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [telegram_id], onDelete: NoAction, onUpdate: NoAction)
}

model settings {
  setting_key   String @id @db.VarChar(50)
  setting_value String @db.Text
}

model admin_logs {
  id         Int       @id @default(autoincrement())
  admin_id   BigInt
  action     String    @db.VarChar(255)
  details    String?   @db.Text
  created_at DateTime? @default(now()) @db.Timestamp(0)
}

model admins {
  id         Int       @id @default(autoincrement())
  username   String    @unique @db.VarChar(50)
  password   String    @db.VarChar(255)
  role       String?   @default("admin") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(0)
}
