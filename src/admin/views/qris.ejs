<div class="content-header">
    <div class="container-fluid"><h1 class="m-0"><%= title %></h1></div>
</div>
<div class="content">
    <div class="container-fluid">
        <button class="btn btn-primary mb-3" data-toggle="modal" data-target="#addQrisModal"><i class="fas fa-plus"></i> Tambah QRIS</button>
        <div class="card">
            <div class="card-body">
                <table id="qrisTable" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Gambar</th>
                            <th>Nama QRIS</th>
                            <th>Status</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% qris.forEach(item => { %>
                        <tr>
                            <td><%= item.id %></td>
                            <td><img src="<%= item.qris_image %>" alt="<%= item.qris_name %>" style="max-height: 80px; max-width:80px;"/></td>
                            <td><%= item.qris_name %></td>
                            <td>
                                <% if(item.is_active) { %> <span class="badge badge-success">Aktif</span> <% } else { %> <span class="badge badge-danger">Nonaktif</span> <% } %>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-warning" data-toggle="modal" data-target="#editQrisModal<%= item.id %>">Edit</button>
                                <form action="/admin/qris/<%= item.id %>/toggle" method="POST" style="display:inline;">
                                    <button class="btn btn-sm <%= item.is_active ? 'btn-secondary' : 'btn-success' %>"><%= item.is_active ? 'Nonaktifkan' : 'Aktifkan' %></button>
                                </form>
                                <form action="/admin/qris/<%= item.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Yakin ingin menghapus QRIS ini?');">
                                    <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>

                        <!-- Modal Edit -->
                        <div class="modal fade" id="editQrisModal<%= item.id %>" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form action="/admin/qris/<%= item.id %>?_method=PUT" method="POST" enctype="multipart/form-data">
                                        <div class="modal-header"><h5 class="modal-title">Edit QRIS</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                                        <div class="modal-body">
                                            <div class="form-group">
                                                <label>Nama QRIS</label>
                                                <input type="text" name="qris_name" class="form-control" value="<%= item.qris_name %>" required>
                                            </div>
                                            <div class="form-group">
                                                <label>Ganti Foto (Opsional)</label><br/>
                                                <img src="<%= item.qris_image %>" style="max-height:100px; margin-bottom:10px;" />
                                                <input type="file" name="qris_image" class="form-control-file" accept="image/*">
                                            </div>
                                        </div>
                                        <div class="modal-footer"><button type="submit" class="btn btn-primary">Simpan</button></div>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Add -->
<div class="modal fade" id="addQrisModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/admin/qris" method="POST" enctype="multipart/form-data">
                <div class="modal-header"><h5 class="modal-title">Tambah QRIS</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Nama QRIS</label>
                        <input type="text" name="qris_name" class="form-control" required placeholder="Contoh: QRIS Kilat Store">
                    </div>
                    <div class="form-group">
                        <label>Foto QRIS</label>
                        <input type="file" name="qris_image" class="form-control-file" accept="image/*" required>
                    </div>
                </div>
                <div class="modal-footer"><button type="submit" class="btn btn-primary">Konfirmasi Tambah</button></div>
            </form>
        </div>
    </div>
</div>

<% extraScripts = `
<script>
    $(function () { $('#qrisTable').DataTable({"responsive": true}); });
</script>
` %>
