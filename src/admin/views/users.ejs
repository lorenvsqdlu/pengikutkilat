<div class="content-header">
    <div class="container-fluid">
        <h1 class="m-0"><%= title %></h1>
    </div>
</div>
<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <table id="usersTable" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Telegram ID</th>
                            <th>Username</th>
                            <th>Fullname</th>
                            <th>Balance</th>
                            <th>Status Banned</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.id %></td>
                            <td><%= user.telegram_id %></td>
                            <td><%= user.username %></td>
                            <td><%= user.fullname %></td>
                            <td>Rp <%= parseFloat(user.balance).toLocaleString('id-ID') %></td>
                            <td>
                                <% if(user.is_banned) { %> <span class="badge badge-danger">Banned</span> <% } else { %> <span class="badge badge-success">Active</span> <% } %>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-primary" data-toggle="modal" data-target="#balanceModal<%= user.id %>">Saldo</button>
                                <button class="btn btn-sm btn-warning" data-toggle="modal" data-target="#banModal<%= user.id %>">Ban/Unban</button>
                            </td>
                        </tr>

                        <!-- Modal Balance -->
                        <div class="modal fade" id="balanceModal<%= user.id %>" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form action="/admin/users/<%= user.id %>/balance" method="POST">
                                        <div class="modal-header"><h5 class="modal-title">Atur Saldo - <%= user.username %></h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                                        <div class="modal-body">
                                            <div class="form-group">
                                                <label>Aksi</label>
                                                <select name="action" class="form-control">
                                                    <option value="add">Tambah</option>
                                                    <option value="sub">Kurangi</option>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label>Nominal (Rp)</label>
                                                <input type="number" name="amount" class="form-control" required min="1">
                                            </div>
                                        </div>
                                        <div class="modal-footer"><button type="submit" class="btn btn-primary">Simpan</button></div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <!-- Modal Ban -->
                        <div class="modal fade" id="banModal<%= user.id %>" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form action="/admin/users/<%= user.id %>/ban" method="POST">
                                        <div class="modal-header"><h5 class="modal-title">Ban/Unban - <%= user.username %></h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                                        <div class="modal-body">
                                            <div class="form-group">
                                                <label>Status</label>
                                                <select name="is_banned" class="form-control">
                                                    <option value="true" <%= user.is_banned ? 'selected' : '' %>>Banned</option>
                                                    <option value="false" <%= !user.is_banned ? 'selected' : '' %>>Active</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="modal-footer"><button type="submit" class="btn btn-warning">Simpan</button></div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<% extraScripts = `
<script>
    $(function () {
        $('#usersTable').DataTable({
            "responsive": true, "lengthChange": false, "autoWidth": false,
        });
    });
</script>
` %>
