<div class="content-header">
    <div class="container-fluid"><h1 class="m-0"><%= title %></h1></div>
</div>
<div class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <table id="depsTable" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>User</th>
                            <th>Reference</th>
                            <th>Amount</th>
                            <th>Fee</th>
                            <th>Method</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% deposits.forEach(dep => { %>
                        <tr>
                            <td><%= dep.id %></td>
                            <td><%= dep.users ? dep.users.username : 'Unknown' %></td>
                            <td><%= dep.reference_id %></td>
                            <td>Rp <%= parseFloat(dep.amount).toLocaleString('id-ID') %></td>
                            <td>Rp <%= parseFloat(dep.fee).toLocaleString('id-ID') %></td>
                            <td><%= dep.payment_method %></td>
                            <td>
                                <% if(dep.status === 'Paid' || dep.status === 'Approved'){ %><span class="badge badge-success"><%= dep.status %></span><% } %>
                                <% if(dep.status === 'Pending'){ %><span class="badge badge-warning">Pending</span><% } %>
                                <% if(dep.status === 'Expired' || dep.status === 'Failed' || dep.status === 'Rejected'){ %><span class="badge badge-danger"><%= dep.status %></span><% } %>
                                <% if(dep.proof_image) { %>
                                 <br/><a href="<%= dep.proof_image %>" target="_blank" class="btn btn-xs btn-info mt-1"><i class="fas fa-image"></i> Bukti</a>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<% extraScripts = `
<script>
    $(function () {
        $('#depsTable').DataTable({"responsive": true});
    });
</script>
` %>
