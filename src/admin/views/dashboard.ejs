<!-- Content Header (Page header) -->
<div class="content-header">
    <div class="container-fluid">
      <div class="row mb-2">
        <div class="col-sm-6">
          <h1 class="m-0"><%= title %></h1>
        </div>
      </div>
    </div>
</div>
<!-- /.content-header -->

<!-- Main content -->
<div class="content">
    <div class="container-fluid">
        <!-- Small boxes (Stat box) -->
        <div class="row">
        <div class="col-lg-3 col-6">
            <!-- small box -->
            <div class="small-box bg-info">
            <div class="inner">
                <h3><%= totalOrder %></h3>
                <p>Total Orders</p>
            </div>
            <div class="icon">
                <i class="ion ion-bag"></i>
            </div>
            </div>
        </div>
        <!-- ./col -->
        <div class="col-lg-3 col-6">
            <!-- small box -->
            <div class="small-box bg-success">
            <div class="inner">
                <h3>Rp <%= parseFloat(totalProfit).toLocaleString('id-ID') %></h3>
                <p>Total Profit</p>
            </div>
            <div class="icon">
                <i class="ion ion-stats-bars"></i>
            </div>
            </div>
        </div>
        <!-- ./col -->
        <div class="col-lg-3 col-6">
            <!-- small box -->
            <div class="small-box bg-warning">
            <div class="inner">
                <h3><%= totalUser %></h3>
                <p>User Registrations</p>
            </div>
            <div class="icon">
                <i class="ion ion-person-add"></i>
            </div>
            </div>
        </div>
        <!-- ./col -->
        <div class="col-lg-3 col-6">
            <!-- small box -->
            <div class="small-box bg-danger">
            <div class="inner">
                <h3>Rp <%= parseFloat(totalDeposit).toLocaleString('id-ID') %></h3>
                <p>Total Deposits</p>
            </div>
            <div class="icon">
                <i class="ion ion-pie-graph"></i>
            </div>
            </div>
        </div>
        <!-- ./col -->
        </div>
        <!-- /.row -->

        <div class="row">
           <div class="col-lg-6">
               <div class="info-box">
                  <span class="info-box-icon bg-secondary"><i class="fas fa-wallet"></i></span>
                  <div class="info-box-content">
                     <span class="info-box-text">Total Saldo User</span>
                     <span class="info-box-number">Rp <%= parseFloat(totalSaldoUser).toLocaleString('id-ID') %></span>
                  </div>
               </div>
           </div>
           <div class="col-lg-6">
               <div class="info-box">
                  <span class="info-box-icon bg-danger"><i class="fas fa-undo"></i></span>
                  <div class="info-box-content">
                     <span class="info-box-text">Total Refund</span>
                     <span class="info-box-number">Rp <%= parseFloat(totalRefund).toLocaleString('id-ID') %></span>
                  </div>
               </div>
           </div>
        </div>

        <div class="card">
            <div class="card-header border-transparent">
              <h3 class="card-title">Latest Orders</h3>
            </div>
            <!-- /.card-header -->
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table m-0">
                  <thead>
                  <tr>
                    <th>Order ID</th>
                    <th>Target</th>
                    <th>Status</th>
                    <th>Profit</th>
                  </tr>
                  </thead>
                  <tbody>
                  <% recentOrders.forEach(order => { %>
                  <tr>
                    <td><%= order.id %></td>
                    <td><%= order.target.substring(0, 20) %>...</td>
                    <td>
                      <% if(order.status === 'Completed'){ %><span class="badge badge-success">Completed</span><% } %>
                      <% if(order.status === 'Pending'){ %><span class="badge badge-warning">Pending</span><% } %>
                      <% if(order.status === 'Canceled' || order.status === 'Cancelled'){ %><span class="badge badge-danger">Cancelled</span><% } %>
                      <% if(order.status === 'Processing' || order.status === 'In progress'){ %><span class="badge badge-info"><%= order.status %></span><% } %>
                      <% if(order.status === 'Partial'){ %><span class="badge badge-secondary">Partial</span><% } %>
                    </td>
                    <td>Rp <%= parseFloat(order.profit).toLocaleString('id-ID') %></td>
                  </tr>
                  <% }); %>
                  </tbody>
                </table>
              </div>
              <!-- /.table-responsive -->
            </div>
            <!-- /.card-body -->
          </div>

    </div>
</div>
<!-- /.content -->
